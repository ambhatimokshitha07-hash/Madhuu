<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Profile Card UI</title>

<style>

body{
    background:#eef2ff;
    font-family:Arial;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.card{
    background:white;
    width:300px;
    padding:25px;
    border-radius:15px;
    text-align:center;
    box-shadow:0px 0px 10px lightgray;
}

.card img{
    width:100px;
    height:100px;
    border-radius:50%;
    border:4px solid #4c63ff;
}

h2{
    color:#4c63ff;
    margin:15px 0 5px;
}

p{
    color:gray;
    font-size:15px;
}

button{
    background:#4c63ff;
    color:white;
    border:none;
    padding:10px 20px;
    border-radius:8px;
    cursor:pointer;
    margin-top:15px;
}

button:hover{
    background:#3248d3;
}

</style>
</head>

<body>

<div class="card">

    <img src="https://via.placeholder.com/100" alt="profile">

    <h2>Mokshitha</h2>

    <p>Web Developer & Student</p>

    <p>I love creating simple and beautiful websites using HTML and CSS.</p>

    <button>Follow</button>

</div>

</body>
</html>
